# Absolute origin of the Swipely backend API (REST + WebSocket).
#
# Leave unset for local dev (Vite proxies /api to localhost:3001) and for
# the Docker/Nginx production image (nginx proxies /api to the backend
# container). Set this when deploying the static build somewhere without
# a same-origin proxy in front of it, e.g. Vercel.
#
# VITE_API_BASE_URL=https://api.example.com
